# Supabase — Projekt in Region EU/Frankfurt anlegen, dann hier eintragen.
# Diese beiden Werte sind öffentlich (Client) und durch RLS abgesichert.
PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-ref.supabase.co"
PUBLIC_SUPABASE_ANON_KEY="YOUR-ANON-KEY"

