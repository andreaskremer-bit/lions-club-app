# Supabase — Projekt in Region EU/Frankfurt anlegen, dann hier eintragen.
# Diese beiden Werte sind öffentlich (Client) und durch RLS abgesichert.
PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-ref.supabase.co"
PUBLIC_SUPABASE_ANON_KEY="YOUR-ANON-KEY"

# Nur serverseitig / CI (NIE an den Client geben). Für M0 noch nicht nötig.
# SUPABASE_SERVICE_ROLE_KEY="YOUR-SERVICE-ROLE-KEY"

# Web-Push: öffentlicher VAPID-Schlüssel (client-sicher). Privater Schlüssel als Edge-Secret.
# PUBLIC_VAPID_KEY="YOUR-VAPID-PUBLIC-KEY"

# Galerie (M6): Link zum geteilten Google-Drive der Fotogalerie. Leer = "noch nicht
# hinterlegt". In Produktion als Netlify-Env-Var setzen.
PUBLIC_GALLERY_URL=""
