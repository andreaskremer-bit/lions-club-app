{
	"plugins": ["react", "import"],
	"rules": {
		"react/forbid-elements": [
			"warn",
			{
				"forbid": []
			}
		],
		"no-restricted-imports": [
			"warn",
			{
				"patterns": [
					{
						"group": [
							"components/core/**",
							"components/feedback/**",
							"components/forms/**",
							"components/navigation/**",
							"ui_kits/club-app/**"
						],
						"message": "Import design-system components from 'index.js', not component internals."
					}
				]
			}
		],
		"no-restricted-syntax": [
			"warn",
			{
				"selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
				"message": "Raw hex color — use a design-system color token via var()."
			},
			{
				"selector": "Literal[value=/\\b\\d+px\\b/]",
				"message": "Raw px value — use a design-system spacing token via var()."
			},
			{
				"selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Source Serif 4|Source Sans 3|Source Code Pro))/i]",
				"message": "Font not provided by the design system. Available: Source Serif 4, Source Sans 3, Source Code Pro."
			},
			{
				"selector": "JSXOpeningElement[name.name='AppBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|eyebrow|leading|trailing|bordered|center|large|className|key|ref|className|style|children)$/]",
				"message": "<AppBar> doesn't accept that prop. Declared props: title, eyebrow, leading, trailing, bordered, center, large, className."
			},
			{
				"selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|src|size|tone|className|key|ref|className|style|children)$/]",
				"message": "<Avatar> doesn't accept that prop. Declared props: name, src, size, tone, className."
			},
			{
				"selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:xs|sm|md|lg|xl)$/]",
				"message": "<Avatar> size must be one of 'xs' | 'sm' | 'md' | 'lg' | 'xl'."
			},
			{
				"selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:gold|blue|cream)$/]",
				"message": "<Avatar> tone must be one of 'gold' | 'blue' | 'cream'."
			},
			{
				"selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|iconLeft|iconRight|fullWidth|as|children|key|ref|className|style|children)$/]",
				"message": "<Button> doesn't accept that prop. Declared props: variant, size, iconLeft, iconRight, fullWidth, as, children."
			},
			{
				"selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|danger)$/]",
				"message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'danger'."
			},
			{
				"selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
				"message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
			},
			{
				"selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='as'] > Literal[value!=/^(?:button|a)$/]",
				"message": "<Button> as must be one of 'button' | 'a'."
			},
			{
				"selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|size|flush|sunken|interactive|as|onClick|className|key|ref|className|style|children)$/]",
				"message": "<Card> doesn't accept that prop. Declared props: children, size, flush, sunken, interactive, as, onClick, className."
			},
			{
				"selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:md|lg)$/]",
				"message": "<Card> size must be one of 'md' | 'lg'."
			},
			{
				"selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|description|radio|name|checked|defaultChecked|onChange|disabled|value|className|key|ref|className|style|children)$/]",
				"message": "<Checkbox> doesn't accept that prop. Declared props: label, description, radio, name, checked, defaultChecked, onChange, disabled, value, className."
			},
			{
				"selector": "JSXOpeningElement[name.name='HintCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|children|tone|icon|className|key|ref|className|style|children)$/]",
				"message": "<HintCard> doesn't accept that prop. Declared props: title, children, tone, icon, className."
			},
			{
				"selector": "JSXOpeningElement[name.name='HintCard'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:info|accent|warning|neutral)$/]",
				"message": "<HintCard> tone must be one of 'info' | 'accent' | 'warning' | 'neutral'."
			},
			{
				"selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|label|size|bordered|tone|onClick|disabled|key|ref|className|style|children)$/]",
				"message": "<IconButton> doesn't accept that prop. Declared props: icon, label, size, bordered, tone, onClick, disabled."
			},
			{
				"selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
				"message": "<IconButton> size must be one of 'sm' | 'md' | 'lg'."
			},
			{
				"selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:default|primary)$/]",
				"message": "<IconButton> tone must be one of 'default' | 'primary'."
			},
			{
				"selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|error|required|icon|multiline|key|ref|className|style|children)$/]",
				"message": "<Input> doesn't accept that prop. Declared props: label, hint, error, required, icon, multiline."
			},
			{
				"selector": "JSXOpeningElement[name.name='ListRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:lead|title|subtitle|date|trailing|chevron|interactive|onClick|className|key|ref|className|style|children)$/]",
				"message": "<ListRow> doesn't accept that prop. Declared props: lead, title, subtitle, date, trailing, chevron, interactive, onClick, className."
			},
			{
				"selector": "JSXOpeningElement[name.name='OtpInput'] > JSXAttribute > JSXIdentifier[name!=/^(?:length|value|onChange|className|key|ref|className|style|children)$/]",
				"message": "<OtpInput> doesn't accept that prop. Declared props: length, value, onChange, className."
			},
			{
				"selector": "JSXOpeningElement[name.name='SegmentedControl'] > JSXAttribute > JSXIdentifier[name!=/^(?:options|value|onChange|className|key|ref|className|style|children)$/]",
				"message": "<SegmentedControl> doesn't accept that prop. Declared props: options, value, onChange, className."
			},
			{
				"selector": "JSXOpeningElement[name.name='Select'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|options|placeholder|value|onChange|className|key|ref|className|style|children)$/]",
				"message": "<Select> doesn't accept that prop. Declared props: label, options, placeholder, value, onChange, className."
			},
			{
				"selector": "JSXOpeningElement[name.name='StatusBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:status|children|dotOnly|className|key|ref|className|style|children)$/]",
				"message": "<StatusBadge> doesn't accept that prop. Declared props: status, children, dotOnly, className."
			},
			{
				"selector": "JSXOpeningElement[name.name='StatusBadge'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:yes|no|open|present)$/]",
				"message": "<StatusBadge> status must be one of 'yes' | 'no' | 'open' | 'present'."
			},
			{
				"selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|tone|checked|defaultChecked|onChange|disabled|className|key|ref|className|style|children)$/]",
				"message": "<Switch> doesn't accept that prop. Declared props: label, tone, checked, defaultChecked, onChange, disabled, className."
			},
			{
				"selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:primary|present)$/]",
				"message": "<Switch> tone must be one of 'primary' | 'present'."
			},
			{
				"selector": "JSXOpeningElement[name.name='TabItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|label|icon|iconActive|badge|key|ref|className|style|children)$/]",
				"message": "<TabItem> doesn't accept that prop. Declared props: id, label, icon, iconActive, badge."
			},
			{
				"selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|outline|dot|icon|className|key|ref|className|style|children)$/]",
				"message": "<Tag> doesn't accept that prop. Declared props: children, tone, outline, dot, icon, className."
			},
			{
				"selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|blue|gold|clay|sage)$/]",
				"message": "<Tag> tone must be one of 'neutral' | 'blue' | 'gold' | 'clay' | 'sage'."
			}
		]
	},
	"overrides": [
		{
			"files": ["**/index.js"],
			"rules": {
				"no-restricted-imports": "off"
			}
		}
	],
